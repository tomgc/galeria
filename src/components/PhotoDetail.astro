---
import { Picture, getImage } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import { siblings, type Photo } from '../lib/photos';
import { useTranslations, type Locale } from '../i18n';

interface Props {
  photo: Photo;
  all: Photo[];
  locale: Locale;
}

const { photo, all, locale } = Astro.props;
const { prev, next } = siblings(all, photo);
const t = useTranslations(locale);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const data = photo.data;

// Localización del título/descripción con fallback al español
const title = locale === 'es'
  ? data.title_es
  : data.title_en || data.title_es;
const description =
  (locale === 'es' ? data.description_es : data.description_en || data.description_es) ||
  `${title}${data.species_common_es ? ' — ' + data.species_common_es : ''}${data.location.city ? ', ' + data.location.city : ''}.`;

// Imagen para Open Graph (JPEG 1600px) y para el lightbox (WebP 2400px)
const ogImg = await getImage({
  src: data.image,
  format: 'jpg',
  width: Math.min(1600, data.image.width),
});
const ogAbsolute = new URL(ogImg.src, Astro.site).toString();

const fullImg = await getImage({
  src: data.image,
  format: 'webp',
  width: Math.min(2400, data.image.width),
});

// Fecha localizada
const dateFormatter = locale === 'es' ? 'es-CL' : 'en-US';
const dateLocale = new Date(data.date_taken).toLocaleDateString(dateFormatter, {
  year: 'numeric', month: 'long', day: 'numeric',
});

// JSON-LD ImageObject (autoría, licencia)
const copyrightText = locale === 'es'
  ? 'Todos los derechos reservados.'
  : 'All rights reserved.';
const year = new Date(data.date_taken).getFullYear();
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ImageObject',
  contentUrl: ogAbsolute,
  thumbnailUrl: ogAbsolute,
  name: title,
  description,
  datePublished: new Date(data.date_taken).toISOString(),
  author: { '@type': 'Person', name: 'Tomás González Cifuentes' },
  creator: { '@type': 'Person', name: 'Tomás González Cifuentes' },
  copyrightHolder: { '@type': 'Person', name: 'Tomás González Cifuentes' },
  copyrightNotice: `© ${year} Tomás González Cifuentes. ${copyrightText}`,
  copyrightYear: year,
  license: 'https://creativecommons.org/licenses/by-nc-nd/4.0/',
  acquireLicensePage: `${Astro.site}${locale}/contacto/`,
  ...(data.location.city || data.location.region
    ? { contentLocation: {
        '@type': 'Place',
        name: [data.location.city, data.location.region, data.location.country].filter(Boolean).join(', '),
      } }
    : {}),
  keywords: [
    locale === 'es' ? data.species_common_es : data.species_common_en,
    data.species_scientific,
    ...data.tags,
  ].filter(Boolean).join(', '),
};

// Breadcrumb: Portada > Aves|Paisajes > Foto
const categoryLabel = locale === 'es'
  ? (data.category === 'aves' ? 'Aves' : 'Paisajes')
  : (data.category === 'aves' ? 'Birds' : 'Landscapes');
const homeLabel = locale === 'es' ? 'Portada' : 'Home';
const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: homeLabel, item: `${Astro.site}${locale}/` },
    { '@type': 'ListItem', position: 2, name: categoryLabel, item: `${Astro.site}${locale}/${data.category}/` },
    { '@type': 'ListItem', position: 3, name: title },
  ],
};

// Etiquetas localizadas
const speciesLabel = locale === 'es' ? 'Especie' : 'Species';
const zoomLabel = locale === 'es' ? 'Ver en pantalla completa' : 'View full screen';
const shareLabel = locale === 'es' ? 'Compartir' : 'Share';
const shareCopiedLabel = locale === 'es' ? 'Enlace copiado' : 'Link copied';

// Etiquetas para sección/aria
const navLabel = locale === 'es' ? 'Navegación entre fotografías' : 'Photograph navigation';

---

<!-- JSON-LD: aceptado por Google en cualquier parte del documento. Lo emitimos
     dentro del componente para no obligar a la página padre a duplicar la lógica. -->
<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
<script type="application/ld+json" set:html={JSON.stringify(breadcrumbLd)} />

<article class="photo-detail">
  <header class="head">
    <div class="head-row">
      <h1>{title}</h1>
      <button
        type="button"
        class="share-btn"
        data-share-title={title}
        data-share-text={description}
        data-share-copied={shareCopiedLabel}
        aria-label={shareLabel}
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
             stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="18" cy="5" r="3"/>
          <circle cx="6" cy="12" r="3"/>
          <circle cx="18" cy="19" r="3"/>
          <line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/>
          <line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/>
        </svg>
        <span class="share-label">{shareLabel}</span>
      </button>
    </div>
    <p class="byline">{t('photo.author_line')}</p>
  </header>

  <figure class="hero">
    <Picture
      src={data.image}
      formats={['avif', 'webp']}
      widths={[800, 1600, 2400]}
      sizes="(min-width: 1440px) 1400px, 100vw"
      alt={title}
      loading="eager"
      decoding="async"
      class="photo"
      draggable={false}
    />
    <a
      class="zoom"
      href={fullImg.src}
      data-pswp-width={fullImg.attributes.width ?? data.image.width}
      data-pswp-height={fullImg.attributes.height ?? data.image.height}
      aria-label={zoomLabel}
    >
      <span aria-hidden="true">⤢</span>
    </a>
  </figure>

  {(data.description_es || data.description_en) && (
    <p class="desc">{locale === 'es' ? data.description_es : (data.description_en || data.description_es)}</p>
  )}

  <dl class="meta">
    {((locale === 'es' ? data.species_common_es : data.species_common_en) || data.species_scientific) && (
      <>
        <dt>{speciesLabel}</dt>
        <dd>
          {locale === 'es' ? data.species_common_es : data.species_common_en}
          {data.species_scientific && <em> ({data.species_scientific})</em>}
        </dd>
      </>
    )}

    <dt>{t('photo.taken_on')}</dt>
    <dd>{dateLocale}</dd>

    {(data.location.city || data.location.region) && (
      <>
        <dt>{t('photo.location')}</dt>
        <dd>{[data.location.city, data.location.region, data.location.country].filter(Boolean).join(', ')}</dd>
      </>
    )}

    {data.camera.model && (<>
      <dt>{t('photo.camera')}</dt>
      <dd>{data.camera.model}</dd>
    </>)}
    {data.camera.lens && (<>
      <dt>{t('photo.lens')}</dt>
      <dd>{data.camera.lens}</dd>
    </>)}

    {(data.exif.aperture || data.exif.shutter_speed || data.exif.iso || data.exif.focal_length) && (
      <>
        <dt>{t('photo.exif')}</dt>
        <dd class="exif">
          {data.exif.aperture && <span>{data.exif.aperture}</span>}
          {data.exif.shutter_speed && <span>{data.exif.shutter_speed}</span>}
          {data.exif.iso && <span>ISO {data.exif.iso}</span>}
          {data.exif.focal_length && <span>{data.exif.focal_length}</span>}
        </dd>
      </>
    )}

    {data.tags.length > 0 && (
      <>
        <dt>{t('photo.tags')}</dt>
        <dd class="tags">
          {data.tags.map((tag) => (
            <a href={`${base}/${locale}/tags/${encodeURIComponent(tag)}/`} class="tag">#{tag}</a>
          ))}
        </dd>
      </>
    )}
  </dl>

  <nav class="prev-next" aria-label={navLabel}>
    {prev ? (
      <a class="np-link prev" href={`${base}/${locale}/foto/${prev.id}/`} rel="prev">
        <span class="np-label">← {t('photo.prev')}</span>
        <span class="np-title">{locale === 'es' ? prev.data.title_es : (prev.data.title_en || prev.data.title_es)}</span>
      </a>
    ) : <span />}
    {next ? (
      <a class="np-link next" href={`${base}/${locale}/foto/${next.id}/`} rel="next">
        <span class="np-label">{t('photo.next')} →</span>
        <span class="np-title">{locale === 'es' ? next.data.title_es : (next.data.title_en || next.data.title_es)}</span>
      </a>
    ) : <span />}
  </nav>
</article>

<script>
  // Lightbox individual con import estático para que Astro/Vite bundleen.
  import PhotoSwipeLightbox from 'photoswipe/lightbox';
  import 'photoswipe/style.css';

  function initDetailLightbox() {
    const link = document.querySelector('.zoom[data-pswp-width]');
    if (!link) return;
    const lightbox = new PhotoSwipeLightbox({
      gallery: '.hero',
      children: 'a.zoom',
      pswpModule: () => import('photoswipe'),
      bgOpacity: 0.95,
    });
    lightbox.init();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initDetailLightbox);
  } else {
    initDetailLightbox();
  }

  // Botón compartir: usa Web Share API si está disponible (mobile mayormente)
  // o copia el link al portapapeles como fallback en desktop.
  function initShareButton() {
    const btn = document.querySelector<HTMLButtonElement>('.share-btn');
    if (!btn) return;
    btn.addEventListener('click', async () => {
      const url = window.location.href;
      const title = btn.dataset.shareTitle || document.title;
      const text = btn.dataset.shareText || '';
      const copiedMsg = btn.dataset.shareCopied || 'Copied';

      if (navigator.share) {
        try {
          await navigator.share({ title, text, url });
          return;
        } catch (e) { /* user canceled — sin acción */ }
      }

      // Fallback: copiar al portapapeles
      try {
        await navigator.clipboard.writeText(url);
        const original = btn.querySelector('.share-label')?.textContent;
        const labelEl = btn.querySelector('.share-label');
        if (labelEl) {
          labelEl.textContent = copiedMsg;
          setTimeout(() => { labelEl.textContent = original || ''; }, 1800);
        }
      } catch (e) { /* clipboard no disponible — sin acción */ }
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initShareButton);
  } else {
    initShareButton();
  }
</script>

<style>
  .photo-detail { max-width: 1400px; margin-inline: auto; }
  .head { margin-bottom: 24px; }
  .head-row {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 16px;
  }
  .head h1 { margin-bottom: 4px; flex: 1; }
  .byline { color: var(--fg-muted); font-size: 0.9rem; margin: 0; }

  .share-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin-top: 8px;
    padding: 6px 12px;
    font-size: 0.85rem;
    color: var(--fg-muted);
  }
  .share-btn:hover { color: var(--fg); }
  .share-btn svg { display: block; }
  @media (max-width: 480px) {
    .share-btn .share-label { display: none; }
  }
  .hero { margin: 0 0 24px; position: relative; }
  .photo { width: 100%; height: auto; background: var(--bg-elev); border-radius: var(--radius); }
  .zoom {
    position: absolute;
    inset-block-end: 12px; inset-inline-end: 12px;
    width: 40px; height: 40px;
    display: grid; place-items: center;
    background: rgba(0,0,0,0.55); color: #fff;
    border: 0; border-radius: 999px;
    font-size: 1.2rem; backdrop-filter: blur(4px);
  }
  .zoom:hover { background: rgba(0,0,0,0.8); opacity: 1; }
  .desc { font-size: 1.05rem; max-width: 70ch; }
  .meta {
    display: grid;
    grid-template-columns: max-content 1fr;
    gap: 8px 24px;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    padding: 20px 0; margin: 24px 0;
    font-size: 0.92rem;
  }
  .meta dt {
    color: var(--fg-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-size: 0.75rem; line-height: 1.6;
  }
  .meta dd { margin: 0; }
  .exif { display: flex; flex-wrap: wrap; gap: 14px; font-variant-numeric: tabular-nums; }
  .tags { display: flex; flex-wrap: wrap; gap: 6px; }
  .tag {
    border: 1px solid var(--border); border-radius: 999px;
    padding: 2px 10px; font-size: 0.8rem; color: var(--fg-muted);
  }
  .tag:hover { color: var(--fg); }
  .prev-next { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-top: 32px; }
  .np-link {
    border: 1px solid var(--border); border-radius: var(--radius);
    padding: 14px 18px; display: flex; flex-direction: column; gap: 4px;
  }
  .np-link.next { text-align: right; }
  .np-label { color: var(--fg-muted); font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.05em; }
  .np-title { font-family: var(--font-serif); font-size: 1.05rem; }
  @media (max-width: 640px) {
    .meta { grid-template-columns: 1fr; gap: 2px; }
    .meta dt { margin-top: 12px; }
    .prev-next { grid-template-columns: 1fr; }
    .np-link.next { text-align: left; }
  }
</style>
