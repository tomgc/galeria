---
interface Props {
  gallerySelector: string;
}
const { gallerySelector } = Astro.props;
---

<!-- Sentinel para pasar el selector a un script ES-module bundleado por Astro.
     Usamos data-attribute en vez de define:vars porque define:vars genera un
     script inline y entonces los dynamic imports a bare specifiers
     ('photoswipe/lightbox') no se resuelven en el browser. -->
<span class="sr-only" data-pswp-gallery={gallerySelector}></span>

<script>
  import PhotoSwipeLightbox from 'photoswipe/lightbox';
  import 'photoswipe/style.css';

  function init() {
    const sentinels = document.querySelectorAll<HTMLElement>('[data-pswp-gallery]');
    for (const sentinel of sentinels) {
      const selector = sentinel.dataset.pswpGallery;
      if (!selector || !document.querySelector(selector)) continue;

      const lightbox = new PhotoSwipeLightbox({
        gallery: selector,
        children: 'a[data-pswp-width]',
        pswpModule: () => import('photoswipe'),
        bgOpacity: 0.95,
        showHideAnimationType: 'fade',
        padding: { top: 24, bottom: 24, left: 12, right: 12 },
      });

      let autoplayTimer: ReturnType<typeof setInterval> | null = null;
      const AUTOPLAY_MS = 4000;

      lightbox.on('uiRegister', () => {
        // Botón autoplay (slideshow)
        lightbox.pswp?.ui?.registerElement({
          name: 'autoplay',
          order: 7,
          isButton: true,
          html: '▶',
          ariaLabel: 'Reproducir slideshow',
          onClick: (_e, el, pswp) => {
            if (autoplayTimer) {
              clearInterval(autoplayTimer);
              autoplayTimer = null;
              el.innerHTML = '▶';
              el.setAttribute('aria-label', 'Reproducir slideshow');
            } else {
              autoplayTimer = setInterval(() => pswp.next(), AUTOPLAY_MS);
              el.innerHTML = '⏸';
              el.setAttribute('aria-label', 'Pausar slideshow');
            }
          },
        });

        // Botón "Ver detalles" — navega a la página de detalle de la foto.
        lightbox.pswp?.ui?.registerElement({
          name: 'detail-link',
          order: 9,
          isButton: true,
          html: 'Ver detalles ↗',
          onClick: (_e, _el, pswp) => {
            const href = (pswp.currSlide?.data?.element as HTMLElement | undefined)?.dataset?.detail;
            if (href) window.location.href = href;
          },
        });
      });

      // Detener autoplay al cerrar el lightbox para no dejar timers colgando.
      lightbox.on('close', () => {
        if (autoplayTimer) {
          clearInterval(autoplayTimer);
          autoplayTimer = null;
        }
      });

      lightbox.init();
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
</script>

<style is:global>
  /* El overlay del lightbox siempre oscuro */
  .pswp__bg { background: #000; }

  .pswp__button--detail-link {
    width: auto !important;
    padding: 0 14px;
    color: #fff;
    font: 0.85rem/2.5 system-ui, sans-serif;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    opacity: 0.75;
  }
  .pswp__button--detail-link:hover { opacity: 1; }
</style>
