---
import type { Locale } from '../i18n';

interface Props {
  tags: string[];
  locale: Locale;
  activeTag?: string;
  /** Cantidad de fotos por tag (opcional, para mostrar contador). */
  counts?: Record<string, number>;
}

const { tags, locale, activeTag, counts } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

// Ordenar tags por frecuencia (si tenemos counts) o alfabético
const sorted = [...tags].sort((a, b) => {
  if (counts) return (counts[b] ?? 0) - (counts[a] ?? 0);
  return a.localeCompare(b);
});
---

{sorted.length > 0 && (
  <nav class="tag-filter" aria-label={locale === 'es' ? 'Filtrar por etiqueta' : 'Filter by tag'}>
    {sorted.map((tag) => (
      <a
        href={`${base}/${locale}/tags/${encodeURIComponent(tag)}/`}
        class:list={['tag', { active: tag === activeTag }]}
        rel={tag === activeTag ? 'canonical' : undefined}
      >
        #{tag}{counts?.[tag] != null && <span class="count"> {counts[tag]}</span>}
      </a>
    ))}
  </nav>
)}

<style>
  .tag-filter {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin: 0 0 24px;
  }
  .tag {
    border: 1px solid var(--border);
    border-radius: 999px;
    padding: 4px 12px;
    font-size: 0.82rem;
    color: var(--fg-muted);
    transition: color var(--transition), border-color var(--transition), background-color var(--transition);
  }
  .tag:hover {
    color: var(--fg);
    border-color: var(--fg-muted);
    opacity: 1;
  }
  .tag.active {
    color: var(--bg);
    background: var(--fg);
    border-color: var(--fg);
  }
  .count {
    opacity: 0.6;
    margin-left: 2px;
  }
</style>
