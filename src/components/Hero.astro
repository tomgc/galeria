---
import { Picture, getImage } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import type { Locale } from '../i18n';

interface Props {
  photo: CollectionEntry<'photos'>;
  locale: Locale;
}

const { photo, locale } = Astro.props;
const data = photo.data;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const title = locale === 'es' ? data.title_es : data.title_en || data.title_es;
const description = locale === 'es' ? data.description_es : data.description_en || data.description_es;
const detailHref = `${base}/${locale}/foto/${photo.id}/`;
const place = [data.location.city, data.location.region].filter(Boolean).join(', ');

const fullImg = await getImage({
  src: data.image,
  format: 'webp',
  width: Math.min(2400, data.image.width),
});

const aspectRatio = `${data.image.width} / ${data.image.height}`;
---

<figure class="hero" data-info-open="false" style={`--ratio: ${aspectRatio};`}>
  <a class="thumb" href={detailHref}>
    <Picture
      src={data.image}
      formats={['avif', 'webp']}
      widths={[800, 1600, 2400]}
      sizes="(min-width: 1440px) 1400px, 100vw"
      alt={title}
      loading="eager"
      decoding="async"
      class="photo"
      draggable={false}
    />
    {description && (
      <div class="overlay">
        <p>{description}</p>
      </div>
    )}
  </a>

  <div class="meta">
    <a class="title" href={detailHref}>{title}</a>
    <button
      type="button"
      class="info-btn"
      aria-expanded="false"
      aria-label={locale === 'es' ? 'Mostrar información técnica' : 'Show technical information'}
    >
      <svg width="14" height="14" viewBox="0 0 14 14" aria-hidden="true" focusable="false">
        <line x1="2" y1="7" x2="12" y2="7" />
        <line class="v" x1="7" y1="2" x2="7" y2="12" />
      </svg>
    </button>
    {place && <span class="place">{place}</span>}
  </div>

  <div class="info">
    <div class="info-inner">
      <dl>
        {data.camera.model && (<><dt>{locale === 'es' ? 'Cámara' : 'Camera'}</dt><dd>{data.camera.model}</dd></>)}
        {data.camera.lens && (<><dt>{locale === 'es' ? 'Objetivo' : 'Lens'}</dt><dd>{data.camera.lens}</dd></>)}
        {data.exif.aperture && (<><dt>{locale === 'es' ? 'Apertura' : 'Aperture'}</dt><dd>{data.exif.aperture}</dd></>)}
        {data.exif.shutter_speed && (<><dt>{locale === 'es' ? 'Obtur.' : 'Shutter'}</dt><dd>{data.exif.shutter_speed}</dd></>)}
        {data.exif.iso && (<><dt>ISO</dt><dd>{data.exif.iso}</dd></>)}
        {data.exif.focal_length && (<><dt>{locale === 'es' ? 'Focal' : 'Focal'}</dt><dd>{data.exif.focal_length}</dd></>)}
        <dt>{locale === 'es' ? 'Fecha' : 'Date'}</dt>
        <dd>{new Date(data.date_taken).toLocaleDateString(locale === 'es' ? 'es-CL' : 'en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</dd>
      </dl>
      {data.tags.length > 0 && (
        <div class="info-tags">
          {data.tags.map((tag) => (
            <span class="info-tag">{tag}</span>
          ))}
        </div>
      )}
    </div>
  </div>
</figure>

<style>
  .hero {
    margin: clamp(24px, 3vw, 48px) 0 clamp(56px, 7vw, 96px);
    position: relative;
  }
  .thumb {
    display: block;
    border: 0;
    overflow: hidden;
    background: var(--bg-elev);
    border: 1px solid var(--border);
    aspect-ratio: var(--ratio);
    max-height: 80vh;
    position: relative;
  }
  .photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 600ms ease;
  }
  .hero:hover .photo { transform: scale(1.01); }

  /* Hover: barra inferior con gris semi-transparente, sólo lo del texto. */
  .overlay {
    position: absolute;
    inset-block-end: 0;
    inset-inline: 0;
    padding: 14px clamp(16px, 3vw, 32px);
    background: rgba(30, 30, 30, 0.72);
    color: #fff;
    opacity: 0;
    transition: opacity 200ms ease;
    pointer-events: none;
  }
  .hero:hover .overlay { opacity: 1; }
  @media (hover: none) {
    .overlay { opacity: 1; }
  }
  .overlay p {
    margin: 0;
    max-width: 60ch;
    font-size: 0.95rem;
    line-height: 1.5;
    font-weight: 400;
  }

  .meta {
    margin-top: 16px;
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 4px 16px;
    align-items: baseline;
  }
  .title {
    grid-column: 1;
    grid-row: 1;
    border: 0;
    color: inherit;
    font-weight: 400;
    font-size: clamp(1rem, 1.6vw, 1.15rem);
    line-height: 1.3;
    letter-spacing: -0.005em;
  }
  .title:hover { opacity: 0.7; }
  .place {
    grid-column: 1 / -1;
    grid-row: 2;
    font-size: 12px;
    letter-spacing: 0.04em;
    color: var(--fg-muted);
  }

  .info-btn {
    grid-column: 2;
    grid-row: 1;
    justify-self: end;
    width: 28px;
    height: 28px;
    background: transparent;
    border: 0;
    padding: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--fg-faint);
    cursor: pointer;
    transition: color 160ms ease;
  }
  .info-btn:hover { color: var(--fg); }
  .info-btn svg { display: block; overflow: visible; }
  .info-btn svg line {
    stroke: currentColor;
    stroke-width: 1.25;
    stroke-linecap: square;
  }
  .info-btn svg .v {
    transform-origin: center;
    transition: transform 220ms ease;
  }
  .hero[data-info-open='true'] .info-btn svg .v { transform: scaleY(0); }

  .info {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 280ms ease, margin-top 280ms ease;
    margin-top: 0;
  }
  .hero[data-info-open='true'] .info {
    grid-template-rows: 1fr;
    margin-top: 16px;
  }
  .info-inner {
    overflow: hidden;
    border-top: 1px solid var(--border);
    padding-top: 16px;
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
  }
  @media (min-width: 720px) {
    .info-inner { grid-template-columns: max-content 1fr; gap: 24px; }
  }
  .info-inner dl {
    margin: 0;
    font-family: var(--font-mono);
    font-size: 11px;
    line-height: 1.7;
  }
  .info-inner dt {
    display: inline-block;
    width: 110px;
    color: var(--fg-faint);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-size: 10px;
  }
  .info-inner dd {
    display: inline;
    margin: 0;
    color: var(--fg);
  }
  .info-inner dd::after { content: ''; display: block; }
  .info-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    align-items: flex-start;
  }
  .info-tag {
    padding: 3px 10px;
    border: 1px solid var(--border);
    font-size: 11px;
    letter-spacing: 0.04em;
    color: var(--fg-muted);
    background: transparent;
    font-family: inherit;
  }
</style>

<script>
  // Mismo handler que PhotoCard — al click toggle data-info-open + aria.
  function setupHeroInfoToggle() {
    document.querySelectorAll<HTMLButtonElement>('.hero .info-btn').forEach((btn) => {
      if ((btn as any).__bound) return;
      (btn as any).__bound = true;
      btn.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();
        const fig = btn.closest<HTMLElement>('.hero');
        if (!fig) return;
        const open = fig.dataset.infoOpen === 'true';
        fig.dataset.infoOpen = open ? 'false' : 'true';
        btn.setAttribute('aria-expanded', String(!open));
        const isEs = document.documentElement.lang === 'es';
        btn.setAttribute('aria-label',
          open
            ? (isEs ? 'Mostrar información técnica' : 'Show technical information')
            : (isEs ? 'Ocultar información técnica' : 'Hide technical information'));
      });
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', setupHeroInfoToggle);
  } else {
    setupHeroInfoToggle();
  }
</script>
