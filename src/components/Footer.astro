---
import { useTranslations, type Locale } from '../i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);
const year = new Date().getFullYear();
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<footer class="site-footer">
  <div class="wrap">
    <p class="copy">
      © {year} Tomás González Cifuentes · {t('footer.rights')}
    </p>
    <p class="links">
      <a href={`${base}/rss.xml`} aria-label="RSS feed">RSS</a>
      <span class="sep">·</span>
      <a href={`${base}/lab/`} aria-label="Design lab">Design lab</a>
    </p>
    <p class="note">
      <small>
        {locale === 'es'
          ? 'Las imágenes de este sitio no pueden reproducirse, distribuirse ni utilizarse para entrenar modelos de inteligencia artificial sin autorización escrita del autor.'
          : 'The images on this site may not be reproduced, distributed, or used to train artificial intelligence models without the written permission of the author.'}
      </small>
    </p>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--border);
    padding: 40px clamp(20px, 4vw, 32px);
    color: var(--fg-muted);
    background: var(--bg);
    text-align: center;
  }
  .wrap {
    max-width: var(--maxw);
    margin-inline: auto;
  }
  .copy {
    margin: 0 0 10px;
    font-size: 0.85rem;
    letter-spacing: 0.04em;
    max-width: none;
  }
  .links {
    margin: 0 0 18px;
    font-size: 0.8rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }
  .links a {
    border: 0;
    color: var(--fg-muted);
  }
  .links a:hover { color: var(--fg); opacity: 1; }
  .sep {
    color: var(--fg-faint);
    margin: 0 8px;
  }
  .note {
    margin: 0 auto;
    max-width: 60ch;
    font-size: 0.74rem;
    line-height: 1.55;
    color: var(--fg-muted);
  }
</style>
