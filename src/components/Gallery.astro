---
import type { CollectionEntry } from 'astro:content';
import type { Locale } from '../i18n';
import PhotoCard from './PhotoCard.astro';
import { useTranslations } from '../i18n';

interface Props {
  photos: CollectionEntry<'photos'>[];
  locale: Locale;
  /** Cuántas fotos cargar con loading="eager" (las del viewport inicial). */
  eagerCount?: number;
}

const { photos, locale, eagerCount = 4 } = Astro.props;
const t = useTranslations(locale);
const galleryId = `gallery-${Math.random().toString(36).slice(2, 8)}`;

const PANORAMA_THRESHOLD = 1.8;
const decorated = photos.map((p) => {
  const ratio = p.data.image.width / p.data.image.height;
  const wide = ratio > PANORAMA_THRESHOLD && photos.length > 1;
  return { photo: p, wide, ratio };
});

---

{photos.length === 0 ? (
  <div class="empty">
    <h2>{t('gallery.empty.title')}</h2>
    <p>{t('gallery.empty.body')}</p>
  </div>
) : (
  <>
    <div id={galleryId} class="gallery density-loose" data-masonry data-total={photos.length}>
      {decorated.map(({ photo, wide }, i) => (
        <PhotoCard
          photo={photo}
          locale={locale}
          wide={wide}
          loading={i < eagerCount ? 'eager' : 'lazy'}
        />
      ))}
    </div>

    <div class="infinite-sentinel" data-sentinel-for={galleryId}></div>
  </>
)}

<style>
  .gallery {
    display: grid;
    grid-template-columns: 1fr;
    grid-auto-rows: 4px;
    grid-auto-flow: dense;
    gap: var(--gap);
    /* dos niveles: amplia (default) y compacta */
    --cols-sm: 1;
    --cols-md: 2;
    --cols-lg: 3;
  }
  /* Compacta: fotos más pequeñas que amplia pero no diminutas. Mosaico. */
  .gallery.density-compact {
    --cols-sm: 2;
    --cols-md: 4;
    --cols-lg: 6;
  }
  .gallery.density-compact > :global(.card.wide) {
    grid-column: auto;
  }
  /* En compacta el grid es un mosaico puro: sin título, sin info técnica y
     sin overlay al hover. Sólo las fotos. */
  .gallery.density-compact :global(.card .meta),
  .gallery.density-compact :global(.card .info),
  .gallery.density-compact :global(.card .overlay) {
    display: none !important;
  }

  @media (min-width: 640px) {
    .gallery { grid-template-columns: repeat(var(--cols-sm), 1fr); }
  }
  @media (min-width: 1024px) {
    .gallery { grid-template-columns: repeat(var(--cols-md), 1fr); }
  }
  @media (min-width: 1440px) {
    .gallery { grid-template-columns: repeat(var(--cols-lg), 1fr); }
  }

  /* Astro scopea las clases al cid del componente que las declara. .card
     viene de PhotoCard con su propio cid; sin :global() el selector no
     matchea y las cards filtradas siguen visibles ocupando columnas. */
  .gallery > :global(.card.is-hidden),
  .gallery > :global(.card.filter-out) { display: none !important; }

  .infinite-sentinel {
    height: 1px;
    margin-top: -1px;
  }

  .empty { text-align: center; padding: 12vh 0; color: var(--fg-muted); }
  .empty h2 { color: var(--fg); }
</style>

<script>
  // ── Masonry: cada card toma N filas según su altura natural. ──
  // Para evitar bugs cuando se expande/contrae el panel de info de una card
  // (la altura medida del DOM queda "constrained" por el row-span vigente),
  // calculamos la altura del thumb a partir de su aspect-ratio CSS en lugar
  // de getBoundingClientRect().height.
  function parseRatio(card: HTMLElement): number {
    const raw = card.style.getPropertyValue('--ratio').trim();
    if (!raw) return 1.5;
    const [w, h] = raw.split('/').map((s) => parseFloat(s));
    if (!w || !h) return 1.5;
    return w / h;
  }

  function setupMasonry() {
    const galleries = document.querySelectorAll<HTMLElement>('[data-masonry]');
    if (galleries.length === 0) return;
    const ROW_UNIT = 4;

    function applySpans() {
      for (const gallery of galleries) {
        const style = getComputedStyle(gallery);
        const gap = parseFloat(style.rowGap || style.gap || '12');
        const cards = Array.from(gallery.children).filter(
          (c): c is HTMLElement => (c as HTMLElement).classList?.contains('card'),
        );
        for (const card of cards) {
          if (card.classList.contains('is-hidden') || card.classList.contains('filter-out')) continue;
          const thumb = card.querySelector('.thumb') as HTMLElement | null;
          if (!thumb) continue;
          const thumbW = thumb.getBoundingClientRect().width;
          const ratio = parseRatio(card);
          const thumbH = thumbW / ratio;
          const meta = card.querySelector('.meta') as HTMLElement | null;
          const info = card.querySelector('.info') as HTMLElement | null;
          const metaH = meta?.getBoundingClientRect().height ?? 0;
          const infoH = card.dataset.infoOpen === 'true'
            ? (info?.getBoundingClientRect().height ?? 0)
            : 0;
          const naturalH = Math.ceil(thumbH + metaH + infoH + 12);
          if (naturalH < 10) continue;
          const span = Math.max(1, Math.ceil((naturalH + gap) / (ROW_UNIT + gap)));
          card.style.gridRowEnd = `span ${span}`;
        }
      }
    }

    applySpans();
    // Reintento tras carga de imágenes (algunas pueden no estar listas en el primer pasado).
    setTimeout(applySpans, 60);
    setTimeout(applySpans, 400);

    const ro = new ResizeObserver(() => applySpans());
    for (const gallery of galleries) {
      for (const card of Array.from(gallery.children).filter((c): c is HTMLElement => (c as HTMLElement).classList?.contains('card'))) ro.observe(card);
    }

    let raf = 0;
    window.addEventListener('resize', () => {
      cancelAnimationFrame(raf);
      raf = requestAnimationFrame(applySpans);
    });

    // Reaplicar al abrir/cerrar el panel de info de una card.
    const cardObserver = new MutationObserver((records) => {
      const relevant = records.some((r) =>
        r.type === 'attributes' && r.attributeName === 'data-info-open');
      if (relevant) {
        applySpans();
        // La transición CSS dura ~280ms; reaplicamos varias veces para acompañarla.
        setTimeout(applySpans, 100);
        setTimeout(applySpans, 320);
        setTimeout(applySpans, 500);
      }
    });
    for (const gallery of galleries) {
      for (const card of Array.from(gallery.children).filter((c): c is HTMLElement => (c as HTMLElement).classList?.contains('card'))) {
        cardObserver.observe(card, { attributes: true, attributeFilter: ['data-info-open'] });
      }
    }

    window.addEventListener('gallery:relayout', () => {
      applySpans();
      setTimeout(applySpans, 60);
    });
  }

  // ── Densidad (amplia / compacta) — persistencia en localStorage. ──
  type Density = 'loose' | 'compact';
  const DEFAULT_DENSITY: Density = 'loose';

  function readDensity(): Density {
    const v = localStorage.getItem('galeria.density') as Density | null;
    return v === 'compact' ? 'compact' : DEFAULT_DENSITY;
  }

  function applyDensity(d: Density) {
    document.querySelectorAll<HTMLElement>('.gallery').forEach((g) => {
      g.classList.remove('density-loose', 'density-compact');
      g.classList.add(`density-${d}`);
    });
    document.querySelectorAll<HTMLButtonElement>('.density-btn[data-density]').forEach((b) => {
      b.setAttribute('aria-pressed', b.dataset.density === d ? 'true' : 'false');
    });
    window.dispatchEvent(new Event('gallery:relayout'));
  }

  // ── Scroll infinito: muestra 20 al inicio + 20 cada vez que el sentinel
  //    aparece en pantalla. Se reinicia cuando cambia el filtro de categoría. ──
  const INITIAL = 20;
  const STEP = 20;
  const shown = new WeakMap<HTMLElement, number>();

  function applyVisibility(gallery: HTMLElement) {
    const cards = Array.from(gallery.children).filter((c): c is HTMLElement => (c as HTMLElement).classList?.contains('card')) as HTMLElement[];
    const eligible = cards.filter((c) => !c.classList.contains('filter-out'));
    const limit = shown.get(gallery) ?? INITIAL;
    cards.forEach((c) => c.classList.remove('is-hidden'));
    eligible.forEach((c, i) => c.classList.toggle('is-hidden', i >= limit));
    window.dispatchEvent(new Event('gallery:relayout'));
  }

  function setupInfinite() {
    document.querySelectorAll<HTMLElement>('.gallery[data-masonry]').forEach((gallery) => {
      shown.set(gallery, INITIAL);
      applyVisibility(gallery);

      const sentinel = document.querySelector<HTMLElement>(
        `.infinite-sentinel[data-sentinel-for='${gallery.id}']`,
      );
      if (!sentinel) return;

      const observer = new IntersectionObserver(
        (entries) => {
          for (const e of entries) {
            if (!e.isIntersecting) continue;
            const cards = Array.from(gallery.children).filter((c): c is HTMLElement => (c as HTMLElement).classList?.contains('card')) as HTMLElement[];
            const eligible = cards.filter((c) => !c.classList.contains('filter-out'));
            const current = shown.get(gallery) ?? INITIAL;
            if (current >= eligible.length) return;
            shown.set(gallery, Math.min(eligible.length, current + STEP));
            applyVisibility(gallery);
          }
        },
        { rootMargin: '400px 0px' },
      );
      observer.observe(sentinel);
    });

    // Cuando cambia el filtro externo, reseteamos el "visto" al inicial.
    window.addEventListener('gallery:filter-changed', () => {
      document.querySelectorAll<HTMLElement>('.gallery[data-masonry]').forEach((g) => {
        shown.set(g, INITIAL);
        applyVisibility(g);
      });
    });
  }

  function setupDensityControls() {
    applyDensity(readDensity());
    document.querySelectorAll<HTMLButtonElement>('.density-btn[data-density]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const d = btn.dataset.density as Density;
        localStorage.setItem('galeria.density', d);
        applyDensity(d);
      });
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', () => {
      setupDensityControls();
      setupInfinite();
      setupMasonry();
    });
  } else {
    setupDensityControls();
    setupInfinite();
    setupMasonry();
  }
</script>
