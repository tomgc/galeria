---
import { useTranslations, type Locale } from '../i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);

const otherLocale: Locale = locale === 'es' ? 'en' : 'es';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

// Construir rutas equivalentes en el otro idioma reemplazando el primer segmento.
const currentPath = Astro.url.pathname.replace(base, '').replace(/^\/(es|en)/, '');
const otherLocaleHref = `${base}/${otherLocale}${currentPath || '/'}`;

const home = `${base}/${locale}/`;

// PORTADA, AVES y PAISAJES apuntan a la home — AVES/PAISAJES con hash que el
// script de la home lee como filtro in-page. Desde otras páginas (sobre-mí,
// contacto) el click navega a la home y aplica el filtro al cargar.
// AVES y PAISAJES son toggles acumulativos en la home. Desde otras páginas
// el href navega a la home con el hash apropiado y el script de la home lo
// aplica al cargar. Hash: "#aves", "#paisajes", "#aves+paisajes" o vacío.
const nav = [
  { href: home, label: t('nav.home'), filter: null, kind: 'home' as const },
  { href: `${home}#aves`, label: t('nav.birds'), filter: 'aves', kind: 'toggle' as const },
  { href: `${home}#paisajes`, label: t('nav.landscapes'), filter: 'paisajes', kind: 'toggle' as const },
  { href: `${base}/${locale}/sobre-mi/`, label: t('nav.about'), filter: null, kind: 'link' as const },
  { href: `${base}/${locale}/contacto/`, label: t('nav.contact'), filter: null, kind: 'link' as const },
];
---

<header class="site-header">
  <a class="brand" href={home}>
    <span class="brand-name">Tomás González Cifuentes</span>
    <span class="brand-sub">{t('brand.subtitle')}</span>
  </a>

  <nav class="site-nav" aria-label="Principal" data-locale={locale}>
    {nav.map((item) => {
      const pathOnly = item.href.split('#')[0];
      const isActive =
        item.kind === 'link' &&
        (Astro.url.pathname === pathOnly ||
          Astro.url.pathname === pathOnly.replace(/\/$/, ''));
      return (
        <a
          href={item.href}
          data-filter={item.filter ?? ''}
          data-kind={item.kind}
          aria-current={isActive ? 'page' : undefined}
          class:list={[{ active: isActive }]}
        >
          {item.label}
        </a>
      );
    })}
  </nav>

  <div class="toggles">
    <div class="density" role="group" aria-label={locale === 'es' ? 'Vista' : 'View'}>
      <button
        type="button"
        class="toggle density-btn"
        data-density="loose"
        aria-pressed="true"
        aria-label={locale === 'es' ? 'Vista amplia' : 'Spacious view'}
        title={locale === 'es' ? 'Vista amplia' : 'Spacious view'}
      >
        <svg width="14" height="14" viewBox="0 0 14 14" aria-hidden="true">
          <rect x="1" y="1" width="5" height="5" fill="currentColor" />
          <rect x="8" y="1" width="5" height="5" fill="currentColor" />
          <rect x="1" y="8" width="5" height="5" fill="currentColor" />
          <rect x="8" y="8" width="5" height="5" fill="currentColor" />
        </svg>
      </button>
      <button
        type="button"
        class="toggle density-btn"
        data-density="compact"
        aria-pressed="false"
        aria-label={locale === 'es' ? 'Vista compacta' : 'Compact view'}
        title={locale === 'es' ? 'Vista compacta' : 'Compact view'}
      >
        <svg width="14" height="14" viewBox="0 0 14 14" aria-hidden="true">
          <rect x="0" y="0" width="3" height="3" fill="currentColor" />
          <rect x="5.5" y="0" width="3" height="3" fill="currentColor" />
          <rect x="11" y="0" width="3" height="3" fill="currentColor" />
          <rect x="0" y="5.5" width="3" height="3" fill="currentColor" />
          <rect x="5.5" y="5.5" width="3" height="3" fill="currentColor" />
          <rect x="11" y="5.5" width="3" height="3" fill="currentColor" />
          <rect x="0" y="11" width="3" height="3" fill="currentColor" />
          <rect x="5.5" y="11" width="3" height="3" fill="currentColor" />
          <rect x="11" y="11" width="3" height="3" fill="currentColor" />
        </svg>
      </button>
    </div>
    <a class="toggle" href={otherLocaleHref} hreflang={otherLocale} title={t('lang.switch')}>
      {locale === 'es' ? 'ES / EN' : 'EN / ES'}
    </a>
    <button
      type="button"
      class="toggle toggle-theme"
      id="theme-toggle"
      aria-label={t('theme.toggle')}
      title={t('theme.toggle')}
    >
      ◐
    </button>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 20;
    background: var(--bg);
    display: flex;
    align-items: center;
    gap: 24px;
    padding: 18px clamp(16px, 3vw, 32px);
    border-bottom: 1px solid var(--border);
    flex-wrap: wrap;
  }

  .brand {
    display: inline-flex;
    flex-direction: column;
    line-height: 1.15;
    border: 0;
    text-decoration: none;
    color: inherit;
    flex-shrink: 0;
  }
  .brand-name {
    font-weight: 300;
    font-size: clamp(1.1rem, 2vw, 1.5rem);
    letter-spacing: -0.01em;
  }
  .brand-sub {
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--fg-muted);
    margin-top: 4px;
  }

  .site-nav {
    flex: 1;
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: clamp(14px, 2.5vw, 32px);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--fg-muted);
  }
  .site-nav a {
    border: 0;
    transition: color 160ms ease;
    cursor: pointer;
    position: relative;
    padding-block: 4px;
  }
  .site-nav a:hover,
  .site-nav a.active {
    color: var(--fg);
    opacity: 1;
  }
  /* Toggle de filtro activo: subrayado grueso para que el cambio sea obvio. */
  .site-nav a[data-kind='toggle'].filter-active {
    color: var(--fg);
    opacity: 1;
  }
  .site-nav a[data-kind='toggle'].filter-active::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: -2px;
    height: 2px;
    background: var(--fg);
  }

  .toggles {
    display: flex;
    gap: 8px;
    align-items: center;
    flex-shrink: 0;
  }
  .toggle {
    background: var(--bg);
    border: 1px solid var(--border);
    color: var(--fg-muted);
    padding: 6px 10px;
    font: 500 10px/1 var(--font-sans);
    letter-spacing: 0.2em;
    text-transform: uppercase;
    cursor: pointer;
    transition: color 160ms ease, border-color 160ms ease;
    text-decoration: none;
  }
  .toggle:hover {
    color: var(--fg);
    border-color: var(--fg-muted);
    opacity: 1;
  }
  .toggle-theme {
    font-size: 14px;
    line-height: 1;
    padding: 6px 9px;
  }

  /* Selector de densidad (Vista amplia / compacta) — minimalista, sólo iconos */
  .density {
    display: inline-flex;
    border: 1px solid var(--border);
    border-radius: 0;
  }
  .density-btn {
    background: var(--bg);
    border: 0;
    color: var(--fg-faint);
    padding: 5px 7px;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: color 160ms ease, background 160ms ease;
  }
  .density-btn + .density-btn {
    border-left: 1px solid var(--border);
  }
  .density-btn:hover { color: var(--fg); }
  .density-btn[aria-pressed='true'] {
    color: var(--bg);
    background: var(--fg);
  }

  /* En pantallas chicas el nav cae a una segunda fila, el brand y los toggles
     se quedan en la primera. */
  @media (max-width: 640px) {
    .site-nav {
      flex: 1 0 100%;
      order: 3;
      justify-content: flex-start;
      gap: 14px;
      padding-top: 4px;
    }
  }
</style>

<script>
  // Toggle de tema con persistencia en localStorage.
  const KEY = 'galeria-theme';
  const root = document.documentElement;

  function apply(theme: 'light' | 'dark') {
    root.setAttribute('data-theme', theme);
  }

  function current(): 'light' | 'dark' {
    const stored = localStorage.getItem(KEY);
    if (stored === 'light' || stored === 'dark') return stored;
    return 'light';
  }

  apply(current());

  const btn = document.getElementById('theme-toggle');
  btn?.addEventListener('click', () => {
    const next = current() === 'dark' ? 'light' : 'dark';
    localStorage.setItem(KEY, next);
    apply(next);
  });
</script>
