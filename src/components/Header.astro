---
import { useTranslations, type Locale } from '../i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = useTranslations(locale);

const otherLocale: Locale = locale === 'es' ? 'en' : 'es';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

// Construir rutas equivalentes en el otro idioma reemplazando el primer segmento.
const currentPath = Astro.url.pathname.replace(base, '').replace(/^\/(es|en)/, '');
const otherLocaleHref = `${base}/${otherLocale}${currentPath || '/'}`;

const nav = [
  { href: `${base}/${locale}/`, label: t('nav.home') },
  { href: `${base}/${locale}/aves/`, label: t('nav.birds') },
  { href: `${base}/${locale}/paisajes/`, label: t('nav.landscapes') },
  { href: `${base}/${locale}/mapa/`, label: t('nav.map') },
  { href: `${base}/${locale}/sobre-mi/`, label: t('nav.about') },
  { href: `${base}/${locale}/contacto/`, label: t('nav.contact') },
];
---

<header class="site-header">
  <div class="brand-block">
    <a class="brand" href={`${base}/${locale}/`}>
      <span class="brand-name">Tomás González Cifuentes</span>
      <span class="brand-sub">{t('brand.subtitle')}</span>
    </a>
  </div>

  <nav class="site-nav" aria-label="Principal">
    {nav.map((item) => {
      const isActive = Astro.url.pathname === item.href || Astro.url.pathname === item.href.replace(/\/$/, '');
      return (
        <a
          href={item.href}
          aria-current={isActive ? 'page' : undefined}
          class:list={[{ active: isActive }]}
        >
          {item.label}
        </a>
      );
    })}
  </nav>

  <div class="toggles">
    <a class="toggle" href={otherLocaleHref} hreflang={otherLocale} title={t('lang.switch')}>
      {locale === 'es' ? 'ES / EN' : 'EN / ES'}
    </a>
    <button
      type="button"
      class="toggle toggle-theme"
      id="theme-toggle"
      aria-label={t('theme.toggle')}
      title={t('theme.toggle')}
    >
      ◐
    </button>
  </div>
</header>

<style>
  .site-header {
    text-align: center;
    padding: clamp(48px, 7vw, 80px) 24px 0;
    position: relative;
  }

  .brand-block {
    margin: 0 auto;
  }

  .brand {
    display: inline-flex;
    flex-direction: column;
    line-height: 1.2;
    border: 0;
    text-align: center;
  }
  .brand-name {
    font-weight: 300;
    font-size: clamp(1.5rem, 3.2vw, 2.2rem);
    letter-spacing: -0.015em;
    margin-bottom: 8px;
  }
  .brand-sub {
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--fg-muted);
    margin-bottom: 28px;
  }

  .site-nav {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: clamp(14px, 2.5vw, 32px);
    padding: 16px 0 24px;
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--fg-muted);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    max-width: 880px;
    margin: 0 auto;
  }
  .site-nav a {
    border: 0;
    transition: color 160ms ease;
  }
  .site-nav a:hover, .site-nav a.active { color: var(--fg); opacity: 1; }
  /* Compensa el letter-spacing trailing del último item para centrado visual exacto */
  .site-nav a:last-child { margin-inline-end: -0.18em; }

  .toggles {
    position: fixed;
    top: 16px; right: 16px;
    z-index: 30;
    display: flex;
    gap: 8px;
    align-items: center;
  }
  .toggle {
    background: var(--bg);
    border: 1px solid var(--border);
    color: var(--fg-muted);
    padding: 6px 10px;
    font: 500 10px/1 var(--font-sans);
    letter-spacing: 0.2em;
    text-transform: uppercase;
    cursor: pointer;
    transition: color 160ms ease, border-color 160ms ease;
    text-decoration: none;
  }
  .toggle:hover {
    color: var(--fg);
    border-color: var(--fg-muted);
    opacity: 1;
  }
  .toggle-theme {
    font-size: 14px;
    line-height: 1;
    padding: 6px 9px;
  }
</style>

<script>
  // Toggle de tema con persistencia en localStorage.
  // LIGHT es el default cuando no hay preferencia guardada.
  const KEY = 'galeria-theme';
  const root = document.documentElement;

  function apply(theme: 'light' | 'dark') {
    root.setAttribute('data-theme', theme);
  }

  function current(): 'light' | 'dark' {
    const stored = localStorage.getItem(KEY);
    if (stored === 'light' || stored === 'dark') return stored;
    return 'light'; // default fijo, no respeta prefers-color-scheme
  }

  apply(current());

  const btn = document.getElementById('theme-toggle');
  btn?.addEventListener('click', () => {
    const next = current() === 'dark' ? 'light' : 'dark';
    localStorage.setItem(KEY, next);
    apply(next);
  });
</script>
