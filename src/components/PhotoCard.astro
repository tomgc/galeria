---
import { Picture, getImage } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import type { Locale } from '../i18n';

interface Props {
  photo: CollectionEntry<'photos'>;
  locale: Locale;
  loading?: 'lazy' | 'eager';
  /** Si la foto debe abarcar 2 columnas (panorámicas) en pantallas con >=2 cols. */
  wide?: boolean;
}

const { photo, locale, loading = 'lazy', wide = false } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const data = photo.data;
const title = locale === 'es' ? data.title_es : data.title_en || data.title_es;
const description = locale === 'es' ? data.description_es : data.description_en || data.description_es;
const detailHref = `${base}/${locale}/foto/${photo.id}/`;
const place = [data.location.city, data.location.region].filter(Boolean).join(', ');

// Versión grande para el lightbox (WebP a máx. 2400px)
const fullImg = await getImage({
  src: data.image,
  format: 'webp',
  width: Math.min(2400, data.image.width),
});

const ratio = data.image.width / data.image.height;
const isPortrait = ratio < 0.95;
const isTall = ratio < 0.65;
const isPanorama = ratio > 1.8;

const aspectRatio = `${data.image.width} / ${data.image.height}`;

const sizes = wide
  ? '(min-width: 1440px) 700px, (min-width: 1024px) 66vw, (min-width: 640px) 100vw, 100vw'
  : '(min-width: 1440px) 360px, (min-width: 1024px) 33vw, (min-width: 640px) 50vw, 100vw';

const pictureWidths = wide ? [600, 1200] : [400, 800];

// Fallback SSR para el row-span del masonry (computado en JS al cargar/resize)
const baselineCol = 340;
const cellW = wide ? baselineCol * 2 + 12 : baselineCol;
const fallbackHeight = Math.ceil(cellW / ratio + 90); // 90 = caption (~30) + place (~24) + márgenes
const fallbackSpan = Math.max(1, Math.ceil((fallbackHeight + 12) / 16));
---

<figure
  class:list={['card', { wide, portrait: isPortrait, tall: isTall, panorama: isPanorama }]}
  data-info-open="false"
  data-category={data.category}
  data-tags={data.tags.join(' ')}
  style={`--ratio: ${aspectRatio}; grid-row-end: span ${fallbackSpan};`}
>
  <a
    class="thumb"
    href={fullImg.src}
    data-pswp-width={fullImg.attributes.width ?? data.image.width}
    data-pswp-height={fullImg.attributes.height ?? data.image.height}
    data-detail={detailHref}
  >
    <Picture
      src={data.image}
      formats={['avif', 'webp']}
      widths={pictureWidths}
      sizes={sizes}
      alt={title}
      loading={loading}
      decoding="async"
      class="photo"
      draggable={false}
    />
    {description && (
      <div class="overlay">
        <p>{description}</p>
      </div>
    )}
  </a>

  <div class="meta">
    <a class="title" href={detailHref}>{title}</a>
    <button
      type="button"
      class="info-btn"
      aria-expanded="false"
      aria-label={locale === 'es' ? 'Mostrar información técnica' : 'Show technical information'}
    >
      <svg width="14" height="14" viewBox="0 0 14 14" aria-hidden="true" focusable="false">
        <line x1="2" y1="7" x2="12" y2="7" />
        <line class="v" x1="7" y1="2" x2="7" y2="12" />
      </svg>
    </button>
    {place && <span class="place">{place}</span>}
  </div>

  <div class="info">
    <div class="info-inner">
      <dl>
        {data.camera.model && (<><dt>{locale === 'es' ? 'Cámara' : 'Camera'}</dt><dd>{data.camera.model}</dd></>)}
        {data.camera.lens && (<><dt>{locale === 'es' ? 'Objetivo' : 'Lens'}</dt><dd>{data.camera.lens}</dd></>)}
        {data.exif.aperture && (<><dt>{locale === 'es' ? 'Apertura' : 'Aperture'}</dt><dd>{data.exif.aperture}</dd></>)}
        {data.exif.shutter_speed && (<><dt>{locale === 'es' ? 'Obtur.' : 'Shutter'}</dt><dd>{data.exif.shutter_speed}</dd></>)}
        {data.exif.iso && (<><dt>ISO</dt><dd>{data.exif.iso}</dd></>)}
        {data.exif.focal_length && (<><dt>{locale === 'es' ? 'Focal' : 'Focal'}</dt><dd>{data.exif.focal_length}</dd></>)}
        <dt>{locale === 'es' ? 'Fecha' : 'Date'}</dt>
        <dd>{new Date(data.date_taken).toLocaleDateString(locale === 'es' ? 'es-CL' : 'en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</dd>
        {data.coords && (<><dt>{locale === 'es' ? 'Coord.' : 'Coord.'}</dt><dd>{data.coords.lat.toFixed(3)}, {data.coords.lng.toFixed(3)}</dd></>)}
      </dl>
      {data.tags.length > 0 && (
        <div class="info-tags">
          {data.tags.map((tag) => (
            <button type="button" class="info-tag" data-tag={tag}>{tag}</button>
          ))}
        </div>
      )}
    </div>
  </div>
</figure>

<style>
  .card {
    margin: 0;
    position: relative;
    display: flex;
    flex-direction: column;
  }
  .card.wide { grid-column: span 2; }
  @media (max-width: 639px) {
    .card.wide { grid-column: auto; }
  }

  .thumb {
    display: block;
    border: 0;
    overflow: hidden;
    background: var(--bg-elev);
    border: 1px solid var(--border);
    aspect-ratio: var(--ratio);
    position: relative;
  }
  .photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 360ms ease;
  }
  .card:hover .photo { transform: scale(1.01); }

  /* Hover: barra inferior con fondo blanco translúcido, sólo lo alto del
     texto, sin gradient ni cubrir el resto de la foto. */
  .overlay {
    position: absolute;
    inset-block-end: 0;
    inset-inline: 0;
    padding: 10px 14px;
    background: rgba(255, 255, 255, 0.88);
    color: #1c1c1a;
    -webkit-backdrop-filter: blur(6px);
    backdrop-filter: blur(6px);
    opacity: 0;
    transition: opacity 200ms ease;
    pointer-events: none;
  }
  .card:hover .overlay {
    opacity: 1;
  }
  @media (hover: none) {
    .overlay { opacity: 1; }
  }
  .overlay p {
    margin: 0;
    max-width: 60ch;
    font-size: 0.82rem;
    line-height: 1.4;
    font-weight: 400;
  }

  /* Meta: grid 2-cols, título + [+] en fila 1, lugar en fila 2 */
  .meta {
    margin-top: 12px;
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 4px 12px;
    align-items: baseline;
  }
  .title {
    grid-column: 1;
    grid-row: 1;
    border: 0;
    color: inherit;
    font-weight: 400;
    font-size: 0.95rem;
    line-height: 1.3;
    letter-spacing: -0.005em;
  }
  .title:hover { color: var(--fg); opacity: 0.7; }
  .place {
    grid-column: 1 / -1;
    grid-row: 2;
    font-size: 11px;
    letter-spacing: 0.04em;
    color: var(--fg-muted);
  }

  /* Toggle [+] / [−] como SVG, centrado al pixel */
  .info-btn {
    grid-column: 2;
    grid-row: 1;
    justify-self: end;
    width: 28px;
    height: 28px;
    background: transparent;
    border: 0;
    padding: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--fg-faint);
    cursor: pointer;
    transition: color 160ms ease;
  }
  .info-btn:hover { color: var(--fg); }
  .info-btn svg { display: block; overflow: visible; }
  .info-btn svg line {
    stroke: currentColor;
    stroke-width: 1.25;
    stroke-linecap: square;
  }
  .info-btn svg .v {
    transform-origin: center;
    transition: transform 220ms ease;
  }
  .card[data-info-open='true'] .info-btn svg .v {
    transform: scaleY(0);
  }

  /* Panel de info técnica colapsable */
  .info {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 280ms ease, margin-top 280ms ease;
    margin-top: 0;
  }
  .card[data-info-open='true'] .info {
    grid-template-rows: 1fr;
    margin-top: 12px;
  }
  .info-inner {
    overflow: hidden;
    border-top: 1px solid var(--border);
    padding-top: 12px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .info-inner dl {
    margin: 0;
    font-family: var(--font-mono);
    font-size: 11px;
    line-height: 1.7;
  }
  .info-inner dt {
    display: inline-block;
    width: 80px;
    color: var(--fg-faint);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-size: 10px;
  }
  .info-inner dd {
    display: inline;
    margin: 0;
    color: var(--fg);
  }
  .info-inner dd::after { content: ''; display: block; }
  .info-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
  }
  .info-tag {
    padding: 2px 8px;
    border: 1px solid var(--border);
    font-size: 10px;
    letter-spacing: 0.04em;
    color: var(--fg-muted);
    background: transparent;
    font-family: inherit;
    cursor: pointer;
    transition: color 120ms, border-color 120ms;
  }
  .info-tag:hover { color: var(--fg); border-color: var(--fg-muted); opacity: 1; }
</style>

<script>
  // Toggle del accordion [+] por card. Sincroniza data-info-open, aria-expanded
  // y aria-label dinámicamente.
  function setupInfoToggles() {
    document.querySelectorAll<HTMLButtonElement>('.card .info-btn').forEach((btn) => {
      if ((btn as any).__bound) return;
      (btn as any).__bound = true;
      btn.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();
        const card = btn.closest<HTMLElement>('.card');
        if (!card) return;
        const open = card.dataset.infoOpen === 'true';
        card.dataset.infoOpen = open ? 'false' : 'true';
        btn.setAttribute('aria-expanded', String(!open));
        const isEs = document.documentElement.lang === 'es';
        btn.setAttribute('aria-label',
          open
            ? (isEs ? 'Mostrar información técnica' : 'Show technical information')
            : (isEs ? 'Ocultar información técnica' : 'Hide technical information'));
      });
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', setupInfoToggles);
  } else {
    setupInfoToggles();
  }
</script>
