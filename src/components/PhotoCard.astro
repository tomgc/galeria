---
import { Picture, getImage } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import type { Locale } from '../i18n';

interface Props {
  photo: CollectionEntry<'photos'>;
  locale: Locale;
  loading?: 'lazy' | 'eager';
}

const { photo, locale, loading = 'lazy' } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const data = photo.data;
const title = locale === 'es' ? data.title_es : data.title_en || data.title_es;
const detailHref = `${base}/${locale}/foto/${photo.id}/`;

// Versión grande para el lightbox (WebP a máx. 2400px)
const fullImg = await getImage({
  src: data.image,
  format: 'webp',
  width: Math.min(2400, data.image.width),
});

const ratio = data.image.width / data.image.height;
const isPortrait = ratio < 0.95;
---

<figure class:list={['card', { portrait: isPortrait }]}>
  <a
    class="thumb"
    href={fullImg.src}
    data-pswp-width={fullImg.attributes.width ?? data.image.width}
    data-pswp-height={fullImg.attributes.height ?? data.image.height}
    data-detail={detailHref}
    aria-label={title}
  >
    <Picture
      src={data.image}
      formats={['avif', 'webp']}
      widths={[400, 800]}
      sizes="(min-width: 1440px) 400px, (min-width: 1024px) 33vw, (min-width: 640px) 50vw, 100vw"
      alt={title}
      loading={loading}
      decoding="async"
      class="photo"
      draggable={false}
    />
  </a>
  <figcaption>
    <a class="title" href={detailHref}>{title}</a>
  </figcaption>
</figure>

<style>
  .card {
    margin: 0 0 var(--gap);
    break-inside: avoid;
    page-break-inside: avoid;
    position: relative;
  }
  .thumb {
    display: block;
    border: 0;
    overflow: hidden;
    background: var(--bg-elev);
    border-radius: var(--radius);
  }
  .photo {
    width: 100%;
    height: auto;
    transition: transform 360ms ease, opacity 240ms ease;
  }
  .card:hover .photo {
    transform: scale(1.015);
  }
  figcaption {
    margin-top: 6px;
    font-size: 0.85rem;
    line-height: 1.3;
    color: var(--fg-muted);
  }
  .title {
    border: 0;
    color: inherit;
  }
  .title:hover { color: var(--fg); }
</style>
