---
import { Picture, getImage } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import type { Locale } from '../i18n';

interface Props {
  photo: CollectionEntry<'photos'>;
  locale: Locale;
  loading?: 'lazy' | 'eager';
  /** Si la foto debe abarcar 2 columnas (panorámicas) en pantallas con >=2 cols. */
  wide?: boolean;
}

const { photo, locale, loading = 'lazy', wide = false } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const data = photo.data;
const title = locale === 'es' ? data.title_es : data.title_en || data.title_es;
const detailHref = `${base}/${locale}/foto/${photo.id}/`;

// Versión grande para el lightbox (WebP a máx. 2400px)
const fullImg = await getImage({
  src: data.image,
  format: 'webp',
  width: Math.min(2400, data.image.width),
});

const ratio = data.image.width / data.image.height;
const isPortrait = ratio < 0.95;
const isTall = ratio < 0.65;
const isPanorama = ratio > 1.8;

// Aspect ratio inline para que el navegador reserve la altura correcta antes
// de que la imagen cargue (sin layout shift, sin saltos en el masonry).
const aspectRatio = `${data.image.width} / ${data.image.height}`;

// `sizes` adapta el ancho según el spanning: wide cards ocupan 2 columnas,
// que a su vez varían según breakpoint (1 → 2 → 3 → 4 cols).
const sizes = wide
  ? '(min-width: 1440px) 700px, (min-width: 1024px) 66vw, (min-width: 640px) 100vw, 100vw'
  : '(min-width: 1440px) 360px, (min-width: 1024px) 33vw, (min-width: 640px) 50vw, 100vw';

// Anchos generados: para wide cards necesitamos versiones más grandes
const pictureWidths = wide ? [600, 1200] : [400, 800];

// Fallback SSR para el row-span del masonry. Estimación basada en columna
// de ~340px (caso 4-col desktop). JS recalcula al cargar y al redimensionar.
const baselineCol = 340;
const cellW = wide ? baselineCol * 2 + 12 : baselineCol;
const fallbackHeight = Math.ceil(cellW / ratio + 34); // 34 = caption + margen
const fallbackSpan = Math.max(1, Math.ceil((fallbackHeight + 12) / 16)); // (h+gap)/(rowUnit+gap)
---

<figure
  class:list={['card', { wide, portrait: isPortrait, tall: isTall, panorama: isPanorama }]}
  style={`--ratio: ${aspectRatio}; grid-row-end: span ${fallbackSpan};`}
>
  <a
    class="thumb"
    href={fullImg.src}
    data-pswp-width={fullImg.attributes.width ?? data.image.width}
    data-pswp-height={fullImg.attributes.height ?? data.image.height}
    data-detail={detailHref}
    aria-label={title}
  >
    <Picture
      src={data.image}
      formats={['avif', 'webp']}
      widths={pictureWidths}
      sizes={sizes}
      alt={title}
      loading={loading}
      decoding="async"
      class="photo"
      draggable={false}
    />
  </a>
  <figcaption>
    <a class="title" href={detailHref}>{title}</a>
  </figcaption>
</figure>

<style>
  .card {
    margin: 0;
    position: relative;
    display: flex;
    flex-direction: column;
    /* Card empieza con altura del thumb + caption, sin layout shift.       */
    /* El grid de Gallery.astro le asigna row-span según getBoundingClientRect. */
  }
  .card.wide {
    grid-column: span 2;
  }

  /* En 1 columna (mobile), wide colapsa a 1 col porque no hay con qué */
  @media (max-width: 639px) {
    .card.wide { grid-column: auto; }
  }

  .thumb {
    display: block;
    border: 0;
    overflow: hidden;
    background: var(--bg-elev);
    border-radius: var(--radius);
    aspect-ratio: var(--ratio);
  }
  .photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 360ms ease, opacity 240ms ease;
  }
  .card:hover .photo {
    transform: scale(1.015);
  }

  figcaption {
    margin-top: 6px;
    font-size: 0.85rem;
    line-height: 1.3;
    color: var(--fg-muted);
  }
  .title {
    border: 0;
    color: inherit;
  }
  .title:hover { color: var(--fg); }
</style>
