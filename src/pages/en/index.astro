---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import Gallery from '../../components/Gallery.astro';
import { getAllPhotos } from '../../lib/photos';

const all = await getAllPhotos();

const heroBirds = all.find((p) => p.data.hero && p.data.category === 'aves') ?? null;
const heroLandscapes = all.find((p) => p.data.hero && p.data.category === 'paisajes') ?? null;

const galleryId = 'home-gallery-en';
---

<BaseLayout locale="en" title="Home">
  <div class="heroes" data-heroes>
    {heroBirds && (
      <div data-hero-category="aves"><Hero photo={heroBirds} locale="en" /></div>
    )}
    {heroLandscapes && (
      <div data-hero-category="paisajes"><Hero photo={heroLandscapes} locale="en" /></div>
    )}
  </div>

  <div id={galleryId}>
    <Gallery photos={all} locale="en" eagerCount={heroBirds || heroLandscapes ? 0 : 4} />
  </div>
</BaseLayout>

<script>
  type Cat = 'aves' | 'paisajes';

  function readCat(): Cat {
    const h = location.hash.replace('#', '');
    return h === 'paisajes' ? 'paisajes' : 'aves';
  }

  let state: Cat = readCat();

  function applyFilters() {
    document.querySelectorAll<HTMLElement>('[data-heroes] [data-hero-category]').forEach((h) => {
      h.style.display = h.dataset.heroCategory === state ? '' : 'none';
    });

    document.querySelectorAll<HTMLElement>('.gallery .card').forEach((card) => {
      card.classList.toggle('filter-out', card.dataset.category !== state);
    });

    document.querySelectorAll<HTMLAnchorElement>('.site-nav a[data-kind="toggle"]').forEach((a) => {
      const active = a.dataset.filter === state;
      a.classList.toggle('filter-active', active);
      a.setAttribute('aria-pressed', active ? 'true' : 'false');
    });

    window.dispatchEvent(new Event('gallery:filter-changed'));
  }

  function init() {
    state = readCat();
    applyFilters();

    window.addEventListener('hashchange', () => {
      state = readCat();
      applyFilters();
    });

    document.querySelectorAll<HTMLAnchorElement>('.site-nav a[data-kind="toggle"]').forEach((a) => {
      a.addEventListener('click', (e) => {
        const pathSame =
          a.pathname === location.pathname ||
          a.pathname === location.pathname + '/' ||
          a.pathname + '/' === location.pathname;
        if (!pathSame) return;
        e.preventDefault();
        const f = a.dataset.filter as Cat;
        if (state === f) return;
        state = f;
        const next = f === 'aves' ? '' : '#paisajes';
        history.replaceState(null, '', location.pathname + location.search + next);
        applyFilters();
      });
    });

    document.querySelectorAll<HTMLAnchorElement>('.site-nav a[data-kind="home"]').forEach((a) => {
      a.addEventListener('click', (e) => {
        const pathSame =
          a.pathname === location.pathname ||
          a.pathname === location.pathname + '/' ||
          a.pathname + '/' === location.pathname;
        if (!pathSame) return;
        e.preventDefault();
        state = 'aves';
        history.replaceState(null, '', location.pathname + location.search);
        applyFilters();
        window.scrollTo({ top: 0, behavior: 'smooth' });
      });
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
</script>
