---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import Gallery from '../../components/Gallery.astro';
import Lightbox from '../../components/Lightbox.astro';
import { getAllPhotos } from '../../lib/photos';

const all = await getAllPhotos();
const featured = all.filter((p) => p.data.featured);

const hero = featured[0] ?? null;
const gridPhotos = hero
  ? [...featured.slice(1), ...all.filter((p) => !p.data.featured)].slice(0, 11)
  : all.slice(0, 12);

const heroGalleryId = 'hero-gallery-en';
---

<BaseLayout locale="en" title="Home">
  <section class="intro">
    <h1>Nature photography</h1>
    <p class="lead">
      Birds and landscapes from southern Chile and Patagonia. A patient look at
      the natural world, captured in original photographs.
    </p>
    <p class="note">
      <em>The English version of this site is still being translated. Some
      sections may appear in Spanish.</em>
    </p>
  </section>

  {hero && (
    <div id={heroGalleryId}>
      <Hero photo={hero} locale="en" />
      <Lightbox gallerySelector={`#${heroGalleryId}`} />
    </div>
  )}

  {gridPhotos.length > 0 && (
    <Gallery photos={gridPhotos} locale="en" eagerCount={hero ? 2 : 4} />
  )}
</BaseLayout>

<style>
  .intro { margin-bottom: 32px; max-width: 70ch; }
  .lead { font-size: 1.1rem; color: var(--fg-muted); margin: 0 0 12px; }
  .note { font-size: 0.85rem; color: var(--fg-muted); }
</style>
