---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import Gallery from '../../components/Gallery.astro';
import Lightbox from '../../components/Lightbox.astro';
import { getAllPhotos } from '../../lib/photos';

const all = await getAllPhotos();

const heroBirds = all.find((p) => p.data.hero && p.data.category === 'aves') ?? null;
const heroLandscapes = all.find((p) => p.data.hero && p.data.category === 'paisajes') ?? null;

const galleryId = 'home-gallery-en';
---

<BaseLayout locale="en" title="Home">
  <div class="heroes" data-heroes>
    {heroBirds && (
      <div data-hero-category="aves"><Hero photo={heroBirds} locale="en" /></div>
    )}
    {heroLandscapes && (
      <div data-hero-category="paisajes"><Hero photo={heroLandscapes} locale="en" /></div>
    )}
  </div>

  <div id={galleryId}>
    <Gallery photos={all} locale="en" eagerCount={heroBirds || heroLandscapes ? 0 : 4} />
    <Lightbox gallerySelector={`#${galleryId}`} />
  </div>
</BaseLayout>

<script>
  type State = { aves: boolean; paisajes: boolean };

  function readHash(): State {
    const h = location.hash.replace('#', '');
    if (!h) return { aves: true, paisajes: false };
    const parts = h.split('+').map((s) => s.trim()).filter(Boolean);
    return { aves: parts.includes('aves'), paisajes: parts.includes('paisajes') };
  }

  function writeHash(s: State, replace = false) {
    const parts: string[] = [];
    if (s.aves) parts.push('aves');
    if (s.paisajes) parts.push('paisajes');
    const next = parts.length ? `#${parts.join('+')}` : '';
    if (!next || replace) {
      history.replaceState(null, '', location.pathname + location.search + next);
      applyFilters();
    } else if (location.hash !== next) {
      location.hash = next;
    }
  }

  let state: State = readHash();

  function filterActiveFor(cat: 'aves' | 'paisajes'): boolean {
    if (!state.aves && !state.paisajes) return true;
    if (state.aves && state.paisajes) return true;
    return state[cat];
  }

  function applyFilters() {
    document.querySelectorAll<HTMLElement>('[data-heroes] [data-hero-category]').forEach((h) => {
      const cat = h.dataset.heroCategory as 'aves' | 'paisajes';
      h.style.display = filterActiveFor(cat) ? '' : 'none';
    });

    document.querySelectorAll<HTMLElement>('.gallery .card').forEach((card) => {
      const cat = card.dataset.category as 'aves' | 'paisajes';
      card.classList.toggle('filter-out', !filterActiveFor(cat));
    });

    document.querySelectorAll<HTMLAnchorElement>('.site-nav a[data-kind="toggle"]').forEach((a) => {
      const f = a.dataset.filter as 'aves' | 'paisajes';
      const active = state[f];
      a.classList.toggle('filter-active', active);
      a.setAttribute('aria-pressed', active ? 'true' : 'false');
    });

    window.dispatchEvent(new Event('gallery:filter-changed'));
  }

  function init() {
    state = readHash();
    applyFilters();

    window.addEventListener('hashchange', () => {
      state = readHash();
      applyFilters();
    });

    document.querySelectorAll<HTMLAnchorElement>('.site-nav a[data-kind="toggle"]').forEach((a) => {
      a.addEventListener('click', (e) => {
        const pathSame =
          a.pathname === location.pathname ||
          a.pathname === location.pathname + '/' ||
          a.pathname + '/' === location.pathname;
        if (!pathSame) return;
        e.preventDefault();
        const f = a.dataset.filter as 'aves' | 'paisajes';
        state = { ...state, [f]: !state[f] };
        writeHash(state);
        applyFilters();
      });
    });

    document.querySelectorAll<HTMLAnchorElement>('.site-nav a[data-kind="home"]').forEach((a) => {
      a.addEventListener('click', (e) => {
        const pathSame =
          a.pathname === location.pathname ||
          a.pathname === location.pathname + '/' ||
          a.pathname + '/' === location.pathname;
        if (!pathSame) return;
        e.preventDefault();
        state = { aves: true, paisajes: false };
        writeHash(state, true);
        applyFilters();
        window.scrollTo({ top: 0, behavior: 'smooth' });
      });
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
</script>
