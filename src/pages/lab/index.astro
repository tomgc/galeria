---
// Design lab — landing que lista las variantes de diseño exploratorias.
// Estas páginas son ejercicios paralelos, no parte del sitio en producción.

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const variants = [
  {
    key: 'a-editorial',
    label: 'A — Editorial / Revista',
    blurb: 'Hero a pantalla completa, fotos como historias con párrafos de contexto. Serif generoso, ritmo lento, narrativo.',
    refs: 'NYT photo essays · Magnum Photos · Lens',
    palette: ['#fafafa', '#1a2030', '#7a8c5a'],
  },
  {
    key: 'c-field-notes',
    label: 'C — Field Notes naturalista',
    blurb: 'Cuaderno de campo: papel sepia, tinta marrón, fichas técnicas con EXIF y observaciones. Tipografía itálica + monospace.',
    refs: 'National Geographic Explorer · cuadernos de Darwin · Muir',
    palette: ['#f5efe0', '#3a2818', '#5a7c47'],
  },
  {
    key: 'd-catalogo',
    label: 'D — Catálogo de imprenta',
    blurb: 'Libro de arte: blanco puro, fotos numeradas tipo museo ("Plate I"), captions en mayúsculas trackeadas. Premium archival.',
    refs: 'Phaidon · Steidl · Aperture',
    palette: ['#ffffff', '#000000', '#a8a39a'],
  },
];
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex" />
    <title>Design Lab — Tomás González Cifuentes</title>
    <style>
      :root {
        --bg: #0f0f0f;
        --fg: #f4f1ea;
        --fg-muted: #8a857c;
        --border: #2a2a2a;
      }
      * { box-sizing: border-box; }
      body {
        margin: 0; min-height: 100vh;
        background: var(--bg); color: var(--fg);
        font: 16px/1.55 system-ui, -apple-system, sans-serif;
      }
      .wrap {
        max-width: 1100px;
        margin: 0 auto;
        padding: clamp(40px, 8vw, 80px) clamp(20px, 5vw, 40px);
      }
      h1 {
        font-family: Georgia, serif;
        font-size: clamp(2rem, 5vw, 3.2rem);
        font-weight: 400;
        margin: 0 0 16px;
      }
      .intro {
        max-width: 60ch;
        color: var(--fg-muted);
        margin-bottom: 56px;
        font-size: 1.05rem;
      }
      .intro a { color: var(--fg); }

      .variants {
        display: grid;
        gap: 32px;
        grid-template-columns: 1fr;
      }
      @media (min-width: 720px) {
        .variants { grid-template-columns: repeat(3, 1fr); }
      }

      .card {
        display: flex;
        flex-direction: column;
        gap: 14px;
        padding: 24px;
        border: 1px solid var(--border);
        border-radius: 4px;
        background: #181818;
        color: inherit;
        text-decoration: none;
        transition: border-color 200ms ease, transform 200ms ease;
      }
      .card:hover {
        border-color: var(--fg);
        transform: translateY(-2px);
      }
      .card-label {
        font-family: Georgia, serif;
        font-size: 1.3rem;
        line-height: 1.2;
      }
      .palette { display: flex; gap: 6px; }
      .palette span {
        width: 22px; height: 22px;
        border-radius: 999px;
        border: 1px solid rgba(255, 255, 255, 0.1);
      }
      .blurb { color: var(--fg-muted); font-size: 0.92rem; margin: 0; }
      .refs {
        margin-top: auto;
        font-size: 0.78rem;
        color: var(--fg-muted);
        letter-spacing: 0.04em;
        opacity: 0.7;
      }
      .arrow {
        font-size: 0.85rem;
        color: var(--fg);
        letter-spacing: 0.06em;
        text-transform: uppercase;
      }

      .back {
        display: inline-block;
        margin-bottom: 32px;
        font-size: 0.85rem;
        color: var(--fg-muted);
        letter-spacing: 0.06em;
        text-transform: uppercase;
        text-decoration: none;
      }
      .back:hover { color: var(--fg); }
    </style>
  </head>
  <body>
    <div class="wrap">
      <a class="back" href={`${base}/es/`}>← Volver al sitio actual</a>
      <h1>Design Lab</h1>
      <p class="intro">
        Variantes de diseño exploratorias del sitio. Cada una es una propuesta
        completa con las mismas fotos, distinta personalidad. Compáralas y elige
        en qué dirección quieres llevar la galería.
      </p>

      <div class="variants">
        {variants.map((v) => (
          <a class="card" href={`${base}/lab/${v.key}/`}>
            <span class="card-label">{v.label}</span>
            <div class="palette">
              {v.palette.map((c) => <span style={`background:${c}`} />)}
            </div>
            <p class="blurb">{v.blurb}</p>
            <span class="refs">{v.refs}</span>
            <span class="arrow">Ver variante →</span>
          </a>
        ))}
      </div>
    </div>
  </body>
</html>
