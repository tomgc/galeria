---
import { Picture } from 'astro:assets';
import { getAllPhotos } from '../../lib/photos';

const photos = await getAllPhotos();
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex" />
    <title>Tomás González Cifuentes</title>
    <style>
      /* Variante E — Minimalismo puro.
         Reglas autoimpuestas:
         - Solo system stack. Sin Google Fonts.
         - Sin colores. Solo negro, gris y blanco.
         - Sin bordes, sin sombras, sin gradientes, sin íconos.
         - Sin decoraciones (ni rayitas, ni puntos, ni separadores).
         - Sin nav. Solo el nombre arriba y las fotos abajo. */
      * { box-sizing: border-box; }
      body {
        margin: 0;
        background: #ffffff;
        color: #111111;
        font: 14px/1.6 -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif;
        -webkit-font-smoothing: antialiased;
      }
      img { display: block; max-width: 100%; height: auto; }
      a {
        color: inherit;
        text-decoration: none;
        border-bottom: 1px solid currentColor;
      }
      a:hover { opacity: 0.5; }

      .lab-nav {
        position: fixed;
        top: 16px; left: 16px;
        font-size: 11px;
        color: #999;
        border: 0;
      }

      .wrap {
        max-width: 760px;
        margin: 0 auto;
        padding: 0 24px;
      }

      header {
        padding: 96px 0 64px;
      }
      header h1 {
        margin: 0;
        font-size: 14px;
        font-weight: 400;
        letter-spacing: 0;
      }
      header p {
        margin: 4px 0 0;
        font-size: 14px;
        color: #999;
      }

      figure {
        margin: 0 0 96px;
      }
      .caption {
        margin-top: 12px;
        font-size: 13px;
        line-height: 1.5;
      }
      .caption .place {
        color: #999;
      }

      footer {
        padding: 96px 0 64px;
        font-size: 12px;
        color: #999;
      }

      @media (prefers-color-scheme: dark) {
        body { background: #0a0a0a; color: #e8e8e8; }
        header p, .caption .place, footer, .lab-nav { color: #777; }
      }
    </style>
  </head>
  <body>
    <a class="lab-nav" href={`${base}/lab/`}>← lab</a>

    <div class="wrap">
      <header>
        <h1>Tomás González Cifuentes</h1>
        <p>Fotografía de naturaleza · Chile</p>
      </header>

      {photos.map((photo) => {
        const data = photo.data;
        const year = new Date(data.date_taken).getFullYear();
        const place = [data.location.city, data.location.region]
          .filter(Boolean).join(', ');
        const meta = [place, String(year)].filter(Boolean).join(', ');
        return (
          <figure>
            <Picture
              src={data.image}
              formats={['avif', 'webp']}
              widths={[800, 1600]}
              sizes="(min-width: 800px) 760px, 100vw"
              alt={data.title_es}
              loading="lazy"
            />
            <div class="caption">
              <span>{data.title_es}</span>
              {meta && <span class="place">{' · '}{meta}</span>}
            </div>
          </figure>
        );
      })}

      <footer>
        © Tomás González Cifuentes
      </footer>
    </div>
  </body>
</html>
