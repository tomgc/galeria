---
// Redirección estática a la versión en español (locale por defecto).
// Usamos <meta http-equiv="refresh"> para no requerir JS y mantener SEO básico.
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const target = `${base}/es/`;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <title>Tomás González Cifuentes — Fotografía de naturaleza</title>
    <meta name="robots" content="noindex" />
    <meta http-equiv="refresh" content={`0; url=${target}`} />
    <link rel="canonical" href={target} />
  </head>
  <body>
    <p>
      <a href={target}>Ir al sitio en español</a> /
      <a href={`${base}/en/`}>Go to English version</a>
    </p>
  </body>
</html>
