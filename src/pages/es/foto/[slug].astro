---
import { getImage } from 'astro:assets';
import type { GetStaticPaths } from 'astro';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PhotoDetail from '../../../components/PhotoDetail.astro';
import { getAllPhotos } from '../../../lib/photos';

export const getStaticPaths: GetStaticPaths = async () => {
  const photos = await getAllPhotos();
  return photos.map((photo) => ({
    params: { slug: photo.id },
    props: { photo, all: photos },
  }));
};

const { photo, all } = Astro.props;
const data = photo.data;
const title = data.title_es;
const description = data.description_es ||
  `${title}${data.species_common_es ? ' — ' + data.species_common_es : ''}${data.location.city ? ', ' + data.location.city : ''}.`;

// og:image (1600px JPEG) para compartir en redes
const ogImg = await getImage({
  src: data.image,
  format: 'jpg',
  width: Math.min(1600, data.image.width),
});
---

<BaseLayout locale="es" title={title} description={description} ogImage={ogImg.src}>
  <PhotoDetail photo={photo} all={all} locale="es" />
</BaseLayout>
