---
import { Picture, getImage } from 'astro:assets';
import type { GetStaticPaths } from 'astro';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getAllPhotos, siblings } from '../../../lib/photos';
import { useTranslations } from '../../../i18n';

export const getStaticPaths: GetStaticPaths = async () => {
  const photos = await getAllPhotos();
  return photos.map((photo) => ({
    params: { slug: photo.id },
    props: { photo, all: photos },
  }));
};

const { photo, all } = Astro.props;
const { prev, next } = siblings(all, photo);
const t = useTranslations('es');
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const data = photo.data;

const title = data.title_es;
const description = data.description_es ||
  `${title}${data.species_common_es ? ' — ' + data.species_common_es : ''}${data.location.city ? ', ' + data.location.city : ''}.`;

// Imagen Open Graph (1600px WebP)
const ogImg = await getImage({
  src: data.image,
  format: 'jpg',
  width: Math.min(1600, data.image.width),
});
const ogAbsolute = new URL(ogImg.src, Astro.site).toString();

// Imagen grande para la página (2400px WebP)
const fullImg = await getImage({
  src: data.image,
  format: 'webp',
  width: Math.min(2400, data.image.width),
});

const dateLocale = new Date(data.date_taken).toLocaleDateString('es-CL', {
  year: 'numeric', month: 'long', day: 'numeric',
});

// JSON-LD ImageObject
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ImageObject',
  contentUrl: ogAbsolute,
  thumbnailUrl: ogAbsolute,
  name: title,
  description,
  datePublished: new Date(data.date_taken).toISOString(),
  author: { '@type': 'Person', name: 'Tomás González Cifuentes' },
  creator: { '@type': 'Person', name: 'Tomás González Cifuentes' },
  copyrightHolder: { '@type': 'Person', name: 'Tomás González Cifuentes' },
  copyrightNotice: `© ${new Date(data.date_taken).getFullYear()} Tomás González Cifuentes. Todos los derechos reservados.`,
  copyrightYear: new Date(data.date_taken).getFullYear(),
  license: 'https://creativecommons.org/licenses/by-nc-nd/4.0/',
  acquireLicensePage: `${Astro.site}es/contacto/`,
  ...(data.location.city || data.location.region
    ? { contentLocation: {
        '@type': 'Place',
        name: [data.location.city, data.location.region, data.location.country].filter(Boolean).join(', '),
      } }
    : {}),
  ...(data.species_scientific
    ? { keywords: [data.species_common_es, data.species_scientific, ...data.tags].filter(Boolean).join(', ') }
    : { keywords: data.tags.join(', ') }),
};
---

<BaseLayout locale="es" title={title} description={description} ogImage={ogImg.src}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </Fragment>

  <article class="photo-detail">
    <header class="head">
      <h1>{title}</h1>
      <p class="byline">{t('photo.author_line')}</p>
    </header>

    <figure class="hero">
      <Picture
        src={data.image}
        formats={['avif', 'webp']}
        widths={[800, 1600, 2400]}
        sizes="(min-width: 1440px) 1400px, 100vw"
        alt={title}
        loading="eager"
        decoding="async"
        class="photo"
        draggable={false}
      />
      <a
        class="zoom"
        href={fullImg.src}
        data-pswp-width={fullImg.attributes.width ?? data.image.width}
        data-pswp-height={fullImg.attributes.height ?? data.image.height}
        aria-label="Ver en pantalla completa"
      >
        <span aria-hidden="true">⤢</span>
      </a>
    </figure>

    {data.description_es && <p class="desc">{data.description_es}</p>}

    <dl class="meta">
      {(data.species_common_es || data.species_scientific) && (
        <>
          <dt>Especie</dt>
          <dd>
            {data.species_common_es}
            {data.species_scientific && <em> ({data.species_scientific})</em>}
          </dd>
        </>
      )}

      <dt>{t('photo.taken_on')}</dt>
      <dd>{dateLocale}</dd>

      {(data.location.city || data.location.region) && (
        <>
          <dt>{t('photo.location')}</dt>
          <dd>{[data.location.city, data.location.region, data.location.country].filter(Boolean).join(', ')}</dd>
        </>
      )}

      {data.camera.model && (
        <>
          <dt>{t('photo.camera')}</dt>
          <dd>{data.camera.model}</dd>
        </>
      )}
      {data.camera.lens && (
        <>
          <dt>{t('photo.lens')}</dt>
          <dd>{data.camera.lens}</dd>
        </>
      )}

      {(data.exif.aperture || data.exif.shutter_speed || data.exif.iso || data.exif.focal_length) && (
        <>
          <dt>{t('photo.exif')}</dt>
          <dd class="exif">
            {data.exif.aperture && <span>{data.exif.aperture}</span>}
            {data.exif.shutter_speed && <span>{data.exif.shutter_speed}</span>}
            {data.exif.iso && <span>ISO {data.exif.iso}</span>}
            {data.exif.focal_length && <span>{data.exif.focal_length}</span>}
          </dd>
        </>
      )}

      {data.tags.length > 0 && (
        <>
          <dt>{t('photo.tags')}</dt>
          <dd class="tags">
            {data.tags.map((tag) => (
              <a href={`${base}/es/tags/${encodeURIComponent(tag)}/`} class="tag">#{tag}</a>
            ))}
          </dd>
        </>
      )}
    </dl>

    <nav class="prev-next" aria-label="Navegación entre fotografías">
      {prev ? (
        <a class="np-link prev" href={`${base}/es/foto/${prev.id}/`} rel="prev">
          <span class="np-label">← {t('photo.prev')}</span>
          <span class="np-title">{prev.data.title_es}</span>
        </a>
      ) : <span />}
      {next ? (
        <a class="np-link next" href={`${base}/es/foto/${next.id}/`} rel="next">
          <span class="np-label">{t('photo.next')} →</span>
          <span class="np-title">{next.data.title_es}</span>
        </a>
      ) : <span />}
    </nav>
  </article>

  <script>
    // Lightbox individual sobre la foto principal del detalle.
    // Imports estáticos para que Astro/Vite bundleen correctamente —
    // un dynamic import a bare specifier en script inline NO resuelve en el browser.
    import PhotoSwipeLightbox from 'photoswipe/lightbox';
    import 'photoswipe/style.css';

    function initDetailLightbox() {
      const link = document.querySelector('.zoom[data-pswp-width]');
      if (!link) return;
      const lightbox = new PhotoSwipeLightbox({
        gallery: '.hero',
        children: 'a.zoom',
        pswpModule: () => import('photoswipe'),
        bgOpacity: 0.95,
      });
      lightbox.init();
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initDetailLightbox);
    } else {
      initDetailLightbox();
    }
  </script>
</BaseLayout>

<style>
  .photo-detail { max-width: 1400px; margin-inline: auto; }
  .head { margin-bottom: 24px; }
  .head h1 { margin-bottom: 4px; }
  .byline {
    color: var(--fg-muted);
    font-size: 0.9rem;
    margin: 0;
  }

  .hero {
    margin: 0 0 24px;
    position: relative;
  }
  .photo {
    width: 100%;
    height: auto;
    background: var(--bg-elev);
    border-radius: var(--radius);
  }
  .zoom {
    position: absolute;
    inset-block-end: 12px;
    inset-inline-end: 12px;
    width: 40px; height: 40px;
    display: grid;
    place-items: center;
    background: rgba(0,0,0,0.55);
    color: #fff;
    border: 0;
    border-radius: 999px;
    font-size: 1.2rem;
    backdrop-filter: blur(4px);
  }
  .zoom:hover { background: rgba(0,0,0,0.8); opacity: 1; }

  .desc {
    font-size: 1.05rem;
    max-width: 70ch;
  }

  .meta {
    display: grid;
    grid-template-columns: max-content 1fr;
    gap: 8px 24px;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    padding: 20px 0;
    margin: 24px 0;
    font-size: 0.92rem;
  }
  .meta dt {
    color: var(--fg-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-size: 0.75rem;
    line-height: 1.6;
  }
  .meta dd { margin: 0; }
  .exif {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    font-variant-numeric: tabular-nums;
  }
  .tags { display: flex; flex-wrap: wrap; gap: 6px; }
  .tag {
    border: 1px solid var(--border);
    border-radius: 999px;
    padding: 2px 10px;
    font-size: 0.8rem;
    color: var(--fg-muted);
  }
  .tag:hover { color: var(--fg); }

  .prev-next {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    margin-top: 32px;
  }
  .np-link {
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 14px 18px;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .np-link.next { text-align: right; }
  .np-label { color: var(--fg-muted); font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.05em; }
  .np-title { font-family: var(--font-serif); font-size: 1.05rem; }

  @media (max-width: 640px) {
    .meta { grid-template-columns: 1fr; gap: 2px; }
    .meta dt { margin-top: 12px; }
    .prev-next { grid-template-columns: 1fr; }
    .np-link.next { text-align: left; }
  }
</style>
