---
import BaseLayout from '../../layouts/BaseLayout.astro';

// Schema.org Person para que Google entienda la entidad detrás del sitio
const personLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Tomás González Cifuentes',
  url: `${Astro.site}es/sobre-mi/`,
  jobTitle: 'Fotógrafo de naturaleza',
  description: 'Fotógrafo de naturaleza chileno especializado en aves y paisajes del sur de Chile y la Patagonia.',
  nationality: 'Chilean',
  knowsAbout: ['Bird photography', 'Landscape photography', 'Patagonia', 'Chilean wildlife'],
  workLocation: {
    '@type': 'Country',
    name: 'Chile',
  },
};
---

<BaseLayout
  locale="es"
  title="Sobre mí"
  description="Tomás González Cifuentes — fotógrafo de naturaleza, basado en Chile."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(personLd)} />
  </Fragment>

  <article class="about">
    <h1>Sobre mí</h1>

    <p class="lead">
      Soy Tomás González Cifuentes, fotógrafo de naturaleza basado en Chile.
      Mi trabajo se enfoca en aves y paisajes del sur del continente.
    </p>

    <p>
      <em>[Biografía pendiente: trayectoria, equipo, regiones donde fotografío,
      premios, publicaciones. Reemplaza este párrafo cuando esté lista.]</em>
    </p>

    <p>
      Para colaboraciones, licencias de uso o compra de copias, escríbeme
      desde la <a href={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/es/contacto/`}>página de contacto</a>.
    </p>
  </article>
</BaseLayout>

<style>
  .about { max-width: 65ch; }
  .lead { font-size: 1.1rem; }
</style>
