---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PhotoMap from '../../components/PhotoMap.astro';
import { getAllPhotos } from '../../lib/photos';

const photos = await getAllPhotos();
const located = photos.filter((p) => p.data.coords);
---

<BaseLayout
  locale="es"
  title="Mapa"
  description="Mapa de las ubicaciones donde se tomaron las fotografías de Tomás González Cifuentes — aves y paisajes de Chile y la Patagonia."
>
  <h1>Mapa</h1>
  <p class="lead">
    Cada marcador es una fotografía. Haz click para verla y conocer
    los detalles.
  </p>
  <p class="count">
    {located.length} de {photos.length}
    {photos.length === 1 ? 'fotografía con ubicación' : 'fotografías con ubicación'}.
  </p>

  <PhotoMap photos={photos} locale="es" />
</BaseLayout>

<style>
  .lead {
    color: var(--fg-muted);
    margin-bottom: 4px;
    max-width: 70ch;
  }
  .count {
    color: var(--fg-muted);
    font-size: 0.85rem;
    margin: 0 0 24px;
  }
</style>
