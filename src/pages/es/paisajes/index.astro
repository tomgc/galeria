---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Gallery from '../../../components/Gallery.astro';
import TagFilter from '../../../components/TagFilter.astro';
import { getAllPhotos } from '../../../lib/photos';

const all = await getAllPhotos();
const photos = all.filter((p) => p.data.category === 'paisajes');

const counts: Record<string, number> = {};
for (const p of photos) for (const t of p.data.tags) counts[t] = (counts[t] ?? 0) + 1;
const tags = Object.keys(counts);
---

<BaseLayout
  locale="es"
  title="Paisajes"
  description="Galería de paisajes de Chile, la Patagonia y el sur del mundo. Obra original de Tomás González Cifuentes."
>
  <h1>Paisajes</h1>
  <TagFilter tags={tags} locale="es" counts={counts} />
  <Gallery photos={photos} locale="es" />
</BaseLayout>
